# Anthropic configuration
# IMPORTANT: Use ANTHROPIC_API_KEY (without VITE_ prefix) to keep it server-side only
# This prevents the API key from being exposed in the client-side bundle
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
AI_PROVIDER=anthropic
AI_MODEL_ANTHROPIC=claude-sonnet-4-5-20250929
AI_MODEL_OPENAI=gpt-4o-mini

# Convex configuration
VITE_CONVEX_URL=your-convex-deployment-url-here

# Sentry configuration
VITE_SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

#Important! Never commit your `.env` file to version control as it contains sensitive information.
